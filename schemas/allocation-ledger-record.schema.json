{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/allocation-ledger-record.schema.json",
  "title": "Allocation Ledger Record",
  "description": "An audit-ready record describing a proposed multi-beneficiary royalty allocation before settlement execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ledger_id",
    "created_at",
    "allocation_context",
    "royalty_pool",
    "beneficiaries",
    "reserve",
    "integrity_summary",
    "human_review",
    "settlement_state"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "ledger_id": {
      "type": "string",
      "pattern": "^ral_[A-Za-z0-9._-]{8,64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "allocation_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allocation_subject_id",
        "allocation_subject_type",
        "policy_id",
        "currency",
        "evidence_bundle_refs"
      ],
      "properties": {
        "allocation_subject_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "allocation_subject_type": {
          "type": "string",
          "enum": [
            "content",
            "dataset",
            "software",
            "service",
            "model_output",
            "physical_work",
            "workflow",
            "other"
          ]
        },
        "policy_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "evidence_bundle_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "royalty_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gross_amount",
        "deduction_amount",
        "allocatable_amount",
        "source_refs"
      ],
      "properties": {
        "gross_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "deduction_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "allocatable_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "beneficiaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/beneficiaryAllocation"
      }
    },
    "reserve": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "holdback_amount",
        "rounding_remainder_amount",
        "unallocated_amount"
      ],
      "properties": {
        "holdback_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "rounding_remainder_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "unallocated_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "reserve_reason_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "integrity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared_weight_total",
        "declared_payable_amount",
        "declared_held_amount",
        "declared_allocated_amount",
        "integrity_status"
      ],
      "properties": {
        "declared_weight_total": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.000001
        },
        "declared_payable_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_held_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_allocated_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "integrity_status": {
          "type": "string",
          "enum": [
            "unverified",
            "verified",
            "failed"
          ]
        },
        "integrity_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "settlement_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "execution_prohibited"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review_pending",
            "approved_for_handoff",
            "rejected",
            "superseded"
          ]
        },
        "execution_prohibited": {
          "type": "boolean",
          "const": true
        },
        "supersedes_ledger_id": {
          "type": "string",
          "pattern": "^ral_[A-Za-z0-9._-]{8,64}$"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "ref_type"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "ref_type": {
          "type": "string",
          "enum": [
            "origin_record",
            "derivative_record",
            "contribution_record",
            "policy",
            "license",
            "invoice",
            "contract",
            "audit_record",
            "dispute_record",
            "payment_source",
            "other"
          ]
        },
        "digest": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "nonNegativeAmount": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.000001
    },
    "beneficiaryAllocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beneficiary_id",
        "beneficiary_type",
        "structural_role",
        "contribution_weight",
        "gross_allocation_amount",
        "payable_amount",
        "held_amount",
        "allocation_status",
        "evidence_refs",
        "rationale"
      ],
      "properties": {
        "beneficiary_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "beneficiary_type": {
          "type": "string",
          "enum": [
            "person",
            "organization",
            "community_fund",
            "public_fund",
            "collective",
            "other"
          ]
        },
        "structural_role": {
          "type": "string",
          "enum": [
            "origin",
            "derivative",
            "contributor",
            "verifier",
            "infrastructure",
            "community",
            "public_interest",
            "other"
          ]
        },
        "contribution_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.000001
        },
        "gross_allocation_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "payable_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "held_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "allocation_status": {
          "type": "string",
          "enum": [
            "proposed",
            "payable_after_approval",
            "held_for_review",
            "ineligible",
            "rejected"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "payment_endpoint_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "dispute_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    }
  }
}
