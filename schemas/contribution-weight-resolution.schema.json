{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/contribution-weight-resolution.schema.json",
  "title": "Contribution Weight Resolution",
  "description": "An evidence-bound record that translates verified contribution records into normalized beneficiary weights for a later allocation ledger.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resolution_id",
    "created_at",
    "allocation_subject_id",
    "policy_context",
    "input_contributions",
    "resolved_weights",
    "integrity_summary",
    "human_review",
    "downstream_state"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "resolution_id": {
      "type": "string",
      "pattern": "^cwr_[A-Za-z0-9._-]{8,64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "allocation_subject_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "scoring_method",
        "normalization_method",
        "minimum_evidence_confidence",
        "policy_refs"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "scoring_method": {
          "type": "string",
          "enum": [
            "evidence_bound_weighted_sum",
            "policy_fixed_score",
            "human_defined_score",
            "other"
          ]
        },
        "normalization_method": {
          "type": "string",
          "const": "sum_to_one"
        },
        "minimum_evidence_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "policy_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "input_contributions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/inputContribution"
      }
    },
    "resolved_weights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/resolvedWeight"
      }
    },
    "integrity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared_final_score_total",
        "declared_normalized_weight_total",
        "declared_resolved_beneficiary_count",
        "unresolved_contribution_ids",
        "integrity_status"
      ],
      "properties": {
        "declared_final_score_total": {
          "$ref": "#/$defs/nonNegativeScore"
        },
        "declared_normalized_weight_total": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "declared_resolved_beneficiary_count": {
          "type": "integer",
          "minimum": 1
        },
        "unresolved_contribution_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "integrity_status": {
          "type": "string",
          "enum": [
            "unverified",
            "verified",
            "failed"
          ]
        },
        "integrity_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "downstream_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allocation_ledger_generation",
        "automatic_right_creation_prohibited",
        "settlement_execution_prohibited"
      ],
      "properties": {
        "allocation_ledger_generation": {
          "type": "string",
          "enum": [
            "blocked",
            "pending_human_review",
            "eligible_after_approval"
          ]
        },
        "automatic_right_creation_prohibited": {
          "type": "boolean",
          "const": true
        },
        "settlement_execution_prohibited": {
          "type": "boolean",
          "const": true
        },
        "target_ledger_schema_version": {
          "type": "string",
          "const": "0.1.0"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "ref_type"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "ref_type": {
          "type": "string",
          "enum": [
            "origin_record",
            "derivative_record",
            "contribution_record",
            "policy",
            "license",
            "audit_record",
            "dispute_record",
            "human_review_record",
            "other"
          ]
        },
        "digest": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "nonNegativeScore": {
      "type": "number",
      "minimum": 0
    },
    "signedAdjustment": {
      "type": "number",
      "minimum": -1000000,
      "maximum": 1000000
    },
    "factorScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "factor_id",
        "raw_score",
        "policy_coefficient",
        "weighted_score",
        "evidence_refs"
      ],
      "properties": {
        "factor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "raw_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "policy_coefficient": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000000
        },
        "weighted_score": {
          "$ref": "#/$defs/nonNegativeScore"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "notes": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "scoreAdjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adjustment_id",
        "adjustment_code",
        "signed_value",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "adjustment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "adjustment_code": {
          "type": "string",
          "enum": [
            "policy_bonus",
            "policy_penalty",
            "minimum_share_correction",
            "maximum_share_correction",
            "evidence_confidence_correction",
            "human_override",
            "other"
          ]
        },
        "signed_value": {
          "$ref": "#/$defs/signedAdjustment"
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "inputContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contribution_id",
        "beneficiary_id",
        "beneficiary_type",
        "structural_role",
        "evidence_confidence",
        "evidence_refs",
        "factor_scores",
        "adjustments",
        "declared_base_score",
        "declared_adjustment_total",
        "declared_final_score",
        "eligibility_status"
      ],
      "properties": {
        "contribution_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "beneficiary_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "beneficiary_type": {
          "type": "string",
          "enum": [
            "person",
            "organization",
            "community_fund",
            "public_fund",
            "collective",
            "other"
          ]
        },
        "structural_role": {
          "type": "string",
          "enum": [
            "origin",
            "derivative",
            "contributor",
            "verifier",
            "infrastructure",
            "community",
            "public_interest",
            "other"
          ]
        },
        "evidence_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "factor_scores": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/factorScore"
          }
        },
        "adjustments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scoreAdjustment"
          }
        },
        "declared_base_score": {
          "$ref": "#/$defs/nonNegativeScore"
        },
        "declared_adjustment_total": {
          "$ref": "#/$defs/signedAdjustment"
        },
        "declared_final_score": {
          "$ref": "#/$defs/nonNegativeScore"
        },
        "eligibility_status": {
          "type": "string",
          "enum": [
            "eligible",
            "held_for_review",
            "excluded_by_policy"
          ]
        },
        "eligibility_reason": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "resolvedWeight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beneficiary_id",
        "contribution_ids",
        "final_score",
        "normalized_weight",
        "confidence",
        "resolution_status",
        "evidence_refs",
        "rationale"
      ],
      "properties": {
        "beneficiary_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "contribution_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "final_score": {
          "$ref": "#/$defs/nonNegativeScore"
        },
        "normalized_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "resolution_status": {
          "type": "string",
          "enum": [
            "proposed",
            "held_for_review",
            "excluded_by_policy"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    }
  }
}
