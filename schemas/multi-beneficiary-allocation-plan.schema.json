{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/multi-beneficiary-allocation-plan.schema.json",
  "title": "Multi-Beneficiary Allocation Plan",
  "description": "An audit-ready plan that applies ordered allocation rules and approved contribution weights to a royalty pool before generating an Allocation Ledger Record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "created_at",
    "allocation_subject_id",
    "source_resolution",
    "royalty_pool",
    "allocation_policy",
    "policy_allocations",
    "proportional_distribution",
    "beneficiary_totals",
    "reserve",
    "integrity_summary",
    "human_review",
    "downstream_state"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3.0"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^mbap_[A-Za-z0-9._-]{8,64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "allocation_subject_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "source_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution_id",
        "schema_version",
        "human_review_status",
        "integrity_status",
        "declared_normalized_weight_total",
        "source_refs"
      ],
      "properties": {
        "resolution_id": {
          "type": "string",
          "pattern": "^cwr_[A-Za-z0-9._-]{8,64}$"
        },
        "schema_version": {
          "type": "string",
          "const": "0.2.0"
        },
        "human_review_status": {
          "type": "string",
          "const": "approved"
        },
        "integrity_status": {
          "type": "string",
          "const": "verified"
        },
        "declared_normalized_weight_total": {
          "type": "number",
          "const": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "royalty_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "gross_amount",
        "deduction_amount",
        "allocatable_amount",
        "source_refs"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "gross_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "deduction_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "allocatable_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "allocation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "execution_order",
        "rounding_precision",
        "rounding_method",
        "policy_refs"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "execution_order": {
          "type": "array",
          "const": [
            "policy_allocations",
            "reserve",
            "proportional_distribution",
            "rounding_remainder",
            "beneficiary_aggregation"
          ]
        },
        "rounding_precision": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "rounding_method": {
          "type": "string",
          "enum": [
            "half_up",
            "half_even",
            "floor",
            "ceiling",
            "truncate"
          ]
        },
        "policy_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "policy_allocations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyAllocation"
      }
    },
    "proportional_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weight_source_resolution_id",
        "eligible_weight_total",
        "base_amount",
        "distributed_amount",
        "entries"
      ],
      "properties": {
        "weight_source_resolution_id": {
          "type": "string",
          "pattern": "^cwr_[A-Za-z0-9._-]{8,64}$"
        },
        "eligible_weight_total": {
          "type": "number",
          "const": 1
        },
        "base_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "distributed_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/proportionalEntry"
          }
        }
      }
    },
    "beneficiary_totals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/beneficiaryTotal"
      }
    },
    "reserve": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_holdback_amount",
        "dispute_holdback_amount",
        "rounding_remainder_amount",
        "unallocated_amount"
      ],
      "properties": {
        "policy_holdback_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "dispute_holdback_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "rounding_remainder_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "unallocated_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "reserve_reason_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "integrity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared_policy_allocation_total",
        "declared_proportional_distribution_total",
        "declared_beneficiary_total",
        "declared_reserve_total",
        "declared_plan_total",
        "declared_beneficiary_count",
        "integrity_status"
      ],
      "properties": {
        "declared_policy_allocation_total": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_proportional_distribution_total": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_beneficiary_total": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_reserve_total": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_plan_total": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "declared_beneficiary_count": {
          "type": "integer",
          "minimum": 1
        },
        "integrity_status": {
          "type": "string",
          "enum": [
            "unverified",
            "verified",
            "failed"
          ]
        },
        "integrity_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "downstream_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allocation_ledger_generation",
        "automatic_reallocation_prohibited",
        "settlement_execution_prohibited",
        "target_ledger_schema_version"
      ],
      "properties": {
        "allocation_ledger_generation": {
          "type": "string",
          "enum": [
            "blocked",
            "pending_human_review",
            "eligible_after_approval"
          ]
        },
        "automatic_reallocation_prohibited": {
          "type": "boolean",
          "const": true
        },
        "settlement_execution_prohibited": {
          "type": "boolean",
          "const": true
        },
        "target_ledger_schema_version": {
          "type": "string",
          "const": "0.1.0"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "ref_type"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "ref_type": {
          "type": "string",
          "enum": [
            "origin_record",
            "derivative_record",
            "contribution_record",
            "weight_resolution",
            "policy",
            "license",
            "invoice",
            "contract",
            "audit_record",
            "dispute_record",
            "payment_source",
            "human_review_record",
            "other"
          ]
        },
        "digest": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "nonNegativeAmount": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.000001
    },
    "recipientType": {
      "type": "string",
      "enum": [
        "person",
        "organization",
        "community_fund",
        "public_fund",
        "collective",
        "platform",
        "other"
      ]
    },
    "structuralRole": {
      "type": "string",
      "enum": [
        "origin",
        "derivative",
        "contributor",
        "verifier",
        "infrastructure",
        "community",
        "public_interest",
        "platform",
        "other"
      ]
    },
    "policyAllocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allocation_id",
        "priority",
        "recipient_id",
        "recipient_type",
        "structural_role",
        "method",
        "calculation_base_amount",
        "calculated_amount",
        "evidence_refs",
        "rationale"
      ],
      "properties": {
        "allocation_id": {
          "type": "string",
          "pattern": "^pa_[A-Za-z0-9._-]{4,64}$"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "recipient_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "recipient_type": {
          "$ref": "#/$defs/recipientType"
        },
        "structural_role": {
          "$ref": "#/$defs/structuralRole"
        },
        "method": {
          "type": "string",
          "enum": [
            "fixed_amount",
            "percentage_of_allocatable_pool",
            "percentage_of_remaining_pool"
          ]
        },
        "fixed_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "calculation_base_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "calculated_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "weightAdjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applied",
        "signed_delta",
        "rule_refs",
        "rationale"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "signed_delta": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "rule_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "proportionalEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "beneficiary_id",
        "beneficiary_type",
        "structural_role",
        "source_normalized_weight",
        "effective_weight",
        "weight_adjustment",
        "calculation_base_amount",
        "calculated_amount",
        "evidence_refs",
        "rationale"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "pattern": "^pe_[A-Za-z0-9._-]{4,64}$"
        },
        "beneficiary_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "beneficiary_type": {
          "$ref": "#/$defs/recipientType"
        },
        "structural_role": {
          "$ref": "#/$defs/structuralRole"
        },
        "source_normalized_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "effective_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "weight_adjustment": {
          "$ref": "#/$defs/weightAdjustment"
        },
        "calculation_base_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "calculated_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "beneficiaryTotal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beneficiary_id",
        "beneficiary_type",
        "structural_role",
        "component_refs",
        "policy_allocation_amount",
        "proportional_allocation_amount",
        "total_planned_amount",
        "evidence_refs",
        "allocation_status"
      ],
      "properties": {
        "beneficiary_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "beneficiary_type": {
          "$ref": "#/$defs/recipientType"
        },
        "structural_role": {
          "$ref": "#/$defs/structuralRole"
        },
        "component_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "policy_allocation_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "proportional_allocation_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "total_planned_amount": {
          "$ref": "#/$defs/nonNegativeAmount"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "allocation_status": {
          "type": "string",
          "enum": [
            "proposed",
            "held_for_review",
            "excluded_by_policy"
          ]
        }
      }
    }
  }
}
